SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=eyJ...
# Angular (browser-safe — used by scripts/set-env.ts for both dev and prod builds)
SUPABASE_PUBLISHABLE_KEY=eyJ...
API_URL=http://localhost:3000
WS_URL=http://localhost:3000
FINNHUB_API_KEY=...
# Supabase direct PostgreSQL connection — used by Graphile Worker for LISTEN/NOTIFY.
# Find in: Supabase → Project Settings → Database → Connection string → URI (port 5432, NOT 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
PORT=3000
CORS_ORIGIN=https://your-app.vercel.app
