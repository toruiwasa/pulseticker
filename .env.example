SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SECRET_KEY=eyJ...
# Angular (browser-safe — used by scripts/set-env.ts for both dev and prod builds)
SUPABASE_PUBLISHABLE_KEY=eyJ...
API_URL=http://localhost:3000
WS_URL=http://localhost:3000
FINNHUB_API_KEY=...
# Upstash: Dashboard → Data Store → your DB → "Connect" tab → "ioredis / BullMQ" section
# Note: UPSTASH_REDIS_REST_URL (https://...) is incompatible with BullMQ. REST Token not required.
UPSTASH_REDIS_URL=rediss://default:...@...upstash.io:6379
PORT=3000
CORS_ORIGIN=https://your-app.vercel.app
