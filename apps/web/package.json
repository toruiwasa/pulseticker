{
  "name": "web",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "dev": "tsx scripts/set-env.ts && ng serve",
    "start": "ng serve",
    "build": "pnpm --filter @pulseticker/schemas --filter @pulseticker/logging --filter @pulseticker/trading-utils build && tsx scripts/set-env.ts && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false",
    "test:watch": "ng test",
    "test:cov": "ng test --coverage --watch=false"
  },
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@maskito/angular": "^5.3.0",
    "@maskito/core": "^5.3.0",
    "@ng-web-apis/common": "^5.3.0",
    "@ng-web-apis/intersection-observer": "^5.3.0",
    "@ng-web-apis/mutation-observer": "^5.3.0",
    "@ng-web-apis/platform": "^5.3.0",
    "@pulseticker/logging": "workspace:*",
    "@pulseticker/schemas": "workspace:*",
    "@pulseticker/trading-utils": "workspace:*",
    "@supabase/supabase-js": "^2.107.0",
    "@taiga-ui/cdk": "5.10.0",
    "@taiga-ui/core": "5.10.0",
    "@taiga-ui/event-plugins": "^5.0.0",
    "@taiga-ui/i18n": "5.10.0",
    "@taiga-ui/icons": "5.10.0",
    "@taiga-ui/kit": "5.10.0",
    "@taiga-ui/polymorpheus": "^5.0.1",
    "@taiga-ui/styles": "5.10.0",
    "lightweight-charts": "^5.2.0",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "dotenv": "^17.4.2",
    "jsdom": "^28.0.0",
    "less": "^4.6.4",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}